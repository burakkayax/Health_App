<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Sensitive health records and settings must not leave the device through Android cloud backup. -->
        <exclude domain="database" path="health.db" />
        <exclude domain="database" path="health.db-shm" />
        <exclude domain="database" path="health.db-wal" />
        <exclude domain="file" path="datastore/health_preferences.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <!-- Keep device-to-device transfer consistent with the local-first privacy policy. -->
        <exclude domain="database" path="health.db" />
        <exclude domain="database" path="health.db-shm" />
        <exclude domain="database" path="health.db-wal" />
        <exclude domain="file" path="datastore/health_preferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
